    {
      "cell_type": "code",
      "source": [
        "## ESCREVA ABAIXO O TRIGGER\n",
        "\n",
        "query = \"\"\"\n",
        "CREATE TABLE Log_Transacao (\n",
        "    id INT AUTO_INCREMENT PRIMARY KEY,\n",
        "    transacao_id INT,\n",
        "    valor_antigo DECIMAL(10,2),\n",
        "    valor_novo DECIMAL(10,2),\n",
        "    usuario_alteracao VARCHAR(50),\n",
        "    data_alteracao TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n",
        ");\n",
        "\n",
        "DELIMITER $$\n",
        "\n",
        "CREATE TRIGGER tg_auditoria_transacao\n",
        "AFTER UPDATE ON TransacaoRecorrente\n",
        "FOR EACH ROW\n",
        "BEGIN\n",
        "    -- Verifica se o valor realmente foi alterado\n",
        "    IF OLD.valor <> NEW.valor THEN\n",
        "        INSERT INTO Log_Transacao (transacao_id, valor_antigo, valor_novo, usuario_alteracao)\n",
        "        VALUES (OLD.id, OLD.valor, NEW.valor, USER());\n",
        "    END IF;\n",
        "END $$\n",
        "\n",
        "DELIMITER ;\"\"\"\n",
        "\n",
